<%- include('../partials/head', { title: title || 'Dashboard' }) %>
<main class="container">
  <h1>Welcome <%= user.username %></h1>
  <p>Role: <%= user.role %> | Tenant: <%= user.tenantId %></p>
  <nav class="quick-nav">
    <a class="quick-link" href="/labs">Open Lab Console</a>
    <a class="quick-link" href="/api/v1/contacts" target="_blank" rel="noreferrer">Contacts API</a>
    <a class="quick-link" href="/api/v1/deals" target="_blank" rel="noreferrer">Deals API</a>
    <a class="quick-link" href="/api/v1/notes" target="_blank" rel="noreferrer">Notes API</a>
    <a class="quick-link" href="/api/v1/admin/debug/secrets" target="_blank" rel="noreferrer">Admin Debug API</a>
  </nav>
  <p>Search term: <%- searchTerm %></p>
  <section>
    <h2>Latest Notes</h2>
    <ul>
      <% for (const note of notes) { %>
        <li>
          <strong><%= note.entity_type %>:</strong>
          <%- note.body %>
        </li>
      <% } %>
    </ul>
  </section>
  <section>
    <h2>Preferences</h2>
    <pre><%- JSON.stringify(prefs, null, 2) %></pre>
  </section>
</main>
<%- include('../partials/footer') %>
